{
  "id": "changelog-manager",
  "name": "Changelog Manager",
  "description": "Automatically manages CHANGELOG.md updates with user confirmation",
  "version": "1.0.0",
  "priority": "medium",
  "capabilities": [
    "Parse existing CHANGELOG.md",
    "Generate changelog entries",
    "Categorize changes (Added/Fixed/Changed/Removed)",
    "Follow Keep a Changelog format",
    "Request user confirmation before updates"
  ],
  "configuration": {
    "changelogPath": "CHANGELOG.md",
    "format": "keepachangelog",
    "sections": [
      "Added",
      "Changed",
      "Deprecated",
      "Removed",
      "Fixed",
      "Security"
    ],
    "versionFormat": "semver",
    "dateFormat": "YYYY-MM-DD"
  },
  "templates": {
    "feature": {
      "section": "Added",
      "format": "**{title}**: {description}",
      "examples": [
        "**User Authentication**: Complete login/logout system with session management",
        "**Export PDF**: Export projects to PDF format with custom templates"
      ]
    },
    "bugfix": {
      "section": "Fixed",
      "format": "**{title}**: {description}",
      "examples": [
        "**Modal Close Issue**: Fixed modal not closing on ESC key press",
        "**Data Persistence**: Resolved issue with projects not saving correctly"
      ]
    },
    "change": {
      "section": "Changed",
      "format": "**{title}**: {description}",
      "examples": [
        "**Navigation Flow**: Improved navigation between sections",
        "**Performance**: Optimized feature table rendering"
      ]
    }
  },
  "autoDetection": {
    "keywords": {
      "added": ["add", "new", "create", "implement", "feature"],
      "fixed": ["fix", "resolve", "repair", "correct", "bug"],
      "changed": ["update", "improve", "enhance", "refactor", "optimize"],
      "removed": ["remove", "delete", "deprecate"]
    }
  },
  "workflow": [
    {
      "step": 1,
      "action": "Detect change type from description"
    },
    {
      "step": 2,
      "action": "Generate changelog entry"
    },
    {
      "step": 3,
      "action": "Show preview to user"
    },
    {
      "step": 4,
      "action": "Request confirmation"
    },
    {
      "step": 5,
      "action": "Update CHANGELOG.md if confirmed"
    }
  ],
  "rules": [
    {
      "id": "user-confirmation",
      "description": "Always ask user before updating",
      "severity": "error"
    },
    {
      "id": "format-consistency",
      "description": "Maintain existing changelog format",
      "severity": "error"
    },
    {
      "id": "no-duplicate",
      "description": "Avoid duplicate entries",
      "severity": "warning"
    }
  ],
  "integration": {
    "triggers": [
      "After feature implementation",
      "After bugfix completion",
      "Manual request",
      "Part of auto-workflow"
    ],
    "hooks": {
      "post-implementation": true,
      "pre-commit": false,
      "interactive": true
    }
  },
  "prompts": {
    "confirmation": "Would you like to update CHANGELOG.md with this entry?",
    "preview": "Proposed changelog entry:",
    "success": "CHANGELOG.md updated successfully",
    "cancelled": "Changelog update cancelled"
  },
  "unreleased": {
    "handling": "create-if-missing",
    "position": "after-header",
    "format": "## [Unreleased] - {date}"
  }
}