{
  "name": "software-estimation-manager",
  "version": "1.0.0",
  "description": "Desktop application for managing software development cost estimates",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "dev": "concurrently \"npm run build:react:dev\" \"npm run electron:dev\"",
    "electron:dev": "nodemon --watch src/main.js --watch src/preload.js --exec \"electron .\"",
    "build:react": "vite build",
    "build:react:dev": "vite build --watch --mode development",
    "watch": "nodemon --watch src --ext js,html,css --exec \"electron .\"",
    "build": "npm run build:react && electron-builder",
    "build:win": "npm run build:react && electron-builder --win",
    "build:mac": "npm run build:react && electron-builder --mac",
    "build:linux": "electron-builder --linux",
    "dist": "npm run build",
    "pack": "electron-builder --dir",
    "postinstall": "electron-builder install-app-deps",
    "workflow:feature": "node agents/auto-workflow.js feature",
    "workflow:bugfix": "node agents/auto-workflow.js bugfix",
    "workflow:interactive": "node agents/auto-workflow.js interactive",
    "workflow:test-update": "node agents/auto-workflow.js test-update",
    "workflow:changelog": "node agents/auto-workflow.js changelog",
    "workflow:analyze": "node agents/auto-workflow.js analyze",
    "workflow": "node agents/auto-workflow.js interactive",
    "restart": "pkill -f electron && npm run build:react && npm run start",
    "restart:dev": "pkill -f electron && npm run build:react:dev && npm run dev"
  },
  "keywords": [
    "electron",
    "estimation",
    "project-management",
    "cost-calculation"
  ],
  "author": "Your Name",
  "license": "MIT",
  "devDependencies": {
    "@babel/core": "^7.23.6",
    "@babel/preset-env": "^7.23.6",
    "@babel/preset-react": "^7.23.3",
    "@cucumber/cucumber": "^10.3.1",
    "@playwright/test": "^1.40.1",
    "@testing-library/jest-dom": "^6.1.5",
    "@testing-library/react": "^14.1.2",
    "@types/react": "^18.2.45",
    "@types/react-dom": "^18.2.18",
    "@vitejs/plugin-react": "^4.2.1",
    "babel-jest": "^29.7.0",
    "concurrently": "^7.6.0",
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^30.0.5",
    "nodemon": "^3.0.2",
    "playwright": "^1.40.1",
    "typescript": "^5.3.3",
    "vite": "^7.1.3",
    "vite-plugin-electron": "^0.28.4"
  },
  "dependencies": {
    "@anthropic-ai/claude-code": "^1.0.120",
    "@google/gemini-cli": "^0.1.18",
    "@openai/codex": "^0.42.0",
    "electron-store": "^8.1.0",
    "exceljs": "^4.4.0",
    "papaparse": "^5.4.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.20.1",
    "uuid": "^9.0.1",
    "xlsx": "^0.18.5",
    "zustand": "^5.0.8"
  },
  "build": {
    "appId": "com.yourcompany.software-estimation-manager",
    "productName": "Software Estimation Manager",
    "directories": {
      "output": "release"
    },
    "files": [
      "src/**/*",
      "node_modules/**/*",
      "package.json"
    ],
    "win": {
      "target": "nsis",
      "icon": "assets/icon.png"
    },
    "mac": {
      "target": [
        {
          "target": "dir",
          "arch": [
            "arm64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "arm64"
          ]
        }
      ],
      "icon": "assets/icon.png"
    },
    "linux": {
      "target": "AppImage",
      "icon": "assets/icon.png"
    }
  }
}
