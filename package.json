{
  "name": "software-estimation-manager",
  "version": "1.0.0",
  "description": "Desktop application for managing software development cost estimates",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "dev": "concurrently \"npm run build:react:dev\" \"npm run electron:dev\"",
    "electron:dev": "nodemon --watch src/main.js --watch src/preload.js --exec \"electron .\"",
    "build:react": "vite build",
    "build:react:dev": "vite build --watch --mode development",
    "watch": "nodemon --watch src --ext js,html,css --exec \"electron .\"",
    "build": "npm run build:react && electron-builder",
    "build:win": "npm run build:react && electron-builder --win",
    "build:mac": "npm run build:react && electron-builder --mac",
    "build:linux": "electron-builder --linux",
    "dist": "npm run build",
    "pack": "electron-builder --dir",
    "postinstall": "electron-builder install-app-deps",
    "restart": "pkill -f electron && npm run build:react && npm run start",
    "restart:dev": "pkill -f electron && npm run build:react:dev && npm run dev",
    "test": "cucumber-js",
    "test:features": "cucumber-js --profile features",
    "test:projects": "cucumber-js --profile projects",
    "test:phases": "cucumber-js --profile phases",
    "test:calculations": "cucumber-js --profile calculations",
    "test:capacity": "cucumber-js --profile capacity",
    "test:allocations": "cucumber-js --profile allocations",
    "test:assumptions": "cucumber-js --profile assumptions",
    "test:version-history": "cucumber-js --profile version-history",
    "test:tickets": "cucumber-js --profile tickets",
    "test:config": "cucumber-js --profile configuration"
  },
  "keywords": [
    "electron",
    "estimation",
    "project-management",
    "cost-calculation"
  ],
  "author": "Your Name",
  "license": "MIT",
  "devDependencies": {
    "@babel/core": "^7.23.6",
    "@babel/preset-env": "^7.23.6",
    "@babel/preset-react": "^7.23.3",
    "@cucumber/cucumber": "^10.3.1",
    "@types/react": "^18.2.45",
    "@types/react-dom": "^18.2.18",
    "@vitejs/plugin-react": "^4.2.1",
    "concurrently": "^7.6.0",
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1",
    "nodemon": "^3.0.2",
    "tsx": "^4.22.4",
    "typescript": "^5.3.3",
    "vite": "^7.1.3",
    "vite-plugin-electron": "^0.28.4"
  },
  "dependencies": {
    "@github/copilot": "^0.0.357",
    "@openai/codex": "^0.42.0",
    "electron-store": "^8.1.0",
    "exceljs": "^4.4.0",
    "impeccable": "^2.3.2",
    "papaparse": "^5.4.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.20.1",
    "uuid": "^9.0.1",
    "xlsx": "^0.18.5",
    "zustand": "^5.0.8"
  },
  "build": {
    "electronDist": "node_modules/electron/dist",
    "appId": "com.yourcompany.software-estimation-manager",
    "productName": "Software Estimation Manager",
    "directories": {
      "output": "release"
    },
    "files": [
      "src/**/*",
      "node_modules/**/*",
      "package.json"
    ],
    "win": {
      "target": "nsis",
      "icon": "assets/icon.png"
    },
    "mac": {
      "target": [
        {
          "target": "dir",
          "arch": [
            "arm64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "arm64"
          ]
        }
      ],
      "icon": "assets/icon.png"
    },
    "linux": {
      "target": "AppImage",
      "icon": "assets/icon.png"
    }
  }
}
